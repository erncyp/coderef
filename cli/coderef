#!/usr/bin/env python3
"""
coderef — CLI for the stable UUID-based in-source reference system

Commands:
  resolve <uuid>   Resolve a UUID to its location; --context shows source lines
  list             List all UUID anchors and their locations
  check            Audit refs: dangling to_ref: and orphan ref: anchors
  scan             Scan source files and rewrite .coderef (no git commit needed)
  graph            Emit the full anchor→reference graph as JSON
  install          Install the pre-commit hook into the current git repo
"""
import argparse
import json
import re
import shutil
import stat
import subprocess
import sys
from dataclasses import dataclass, field
from pathlib import Path

# ── Patterns ──────────────────────────────────────────────────────────────────

# Single pattern for all ref: marker forms (matches hook's REF_MARKER_RE)
# group(1) = UUID,  group(2) = suffix (start|end|name) or None
REF_MARKER_RE = re.compile(
    r'(?<![a-zA-Z_])ref:([a-f0-9]{8})(?::(start|end|[a-z][a-z0-9-]*))?(?![a-f0-9:])'
)
# Extended to_ref: syntax:
#   to_ref:uuid                     — HEAD ref, no label
#   to_ref:@commit:uuid             — pinned to commit, no label
#   to_ref:name:uuid                — HEAD ref, labelled
#   to_ref:@commit:name:uuid        — pinned + labelled
# The @ sigil unambiguously marks a commit; plain segments are labels.
TO_REF_RE = re.compile(
    r'\bto_ref:((?:@[-A-Za-z0-9._/@]+:)?(?:[a-z][a-z0-9-]*:)?[a-f0-9]{8})(?![a-f0-9:])'
)

REFS_FILENAME = ".coderef"


# ── to_ref: body parser ───────────────────────────────────────────────────────

def _parse_to_ref(body: str) -> dict:
    """
    Parse the body captured after ``to_ref:`` by TO_REF_RE.

    Formats
    -------
    uuid                  → HEAD ref, no label
    @commit:uuid          → pinned to commit, no label
    name:uuid             → HEAD ref, with label
    @commit:name:uuid     → pinned to commit, with label

    The ``@`` sigil is the unambiguous signal for a commit reference.
    Returns {'uuid': str, 'commit': str|None, 'name': str|None}.
    """
    parts = body.split(":")
    uuid  = parts[-1]
    commit: str | None = None
    name:   str | None = None

    rest = parts[:-1]
    if rest and rest[0].startswith("@"):
        commit = rest[0][1:]   # strip leading @
        rest   = rest[1:]

    if rest:
        name = ":".join(rest)

    return {"uuid": uuid, "commit": commit, "name": name}


# ── Data types ────────────────────────────────────────────────────────────────

@dataclass
class RefInfo:
    location: str          # "file:line" or "file:start-end"
    kind: str              # "point" or "range"
    name: str | None = None

    @property
    def display(self) -> str:
        return f"{self.location} ({self.name})" if self.name else self.location

    @property
    def file(self) -> str:
        return self.location.rsplit(":", 1)[0]

    @property
    def start_line(self) -> int:
        suffix = self.location.rsplit(":", 1)[1]
        return int(suffix.split("-")[0])

    @property
    def end_line(self) -> int | None:
        suffix = self.location.rsplit(":", 1)[1]
        parts = suffix.split("-")
        return int(parts[1]) if len(parts) == 2 else None


# ── Low-level helpers ─────────────────────────────────────────────────────────

def find_repo_root() -> Path | None:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True,
        )
        if result.returncode == 0:
            return Path(result.stdout.strip())
    except FileNotFoundError:
        pass
    cur = Path.cwd()
    while True:
        if (cur / REFS_FILENAME).exists():
            return cur
        parent = cur.parent
        if parent == cur:
            return None
        cur = parent


def require_root() -> Path:
    root = find_repo_root()
    if root is None:
        print("error: no git repository or .coderef file found", file=sys.stderr)
        sys.exit(1)
    return root


def tracked_files(root: Path) -> list[str]:
    result = subprocess.run(
        ["git", "ls-files"], capture_output=True, text=True, cwd=root
    )
    return result.stdout.splitlines()


def _parse_refs_line(raw: str) -> tuple[str, str, str | None]:
    """
    Parse a .coderef line value (everything after the UUID).
    Returns (location, kind, name_or_None).

    Formats:
      file:line              → point, no name
      file:line name         → point, named
      file:start-end         → range, no name
    """
    # Try to split off an optional trailing name token
    parts = raw.rsplit(None, 1)
    name: str | None = None
    location = raw

    if len(parts) == 2 and re.match(r'^[a-z][a-z0-9-]*$', parts[1]):
        # The last token looks like a name — but only if the first part is a
        # valid location (ends in :digits or :digits-digits)
        if re.search(r':\d+(-\d+)?$', parts[0]):
            location, name = parts[0], parts[1]

    kind = "range" if re.search(r':\d+-\d+$', location) else "point"
    return location, kind, name


def load_refs(root: Path) -> dict[str, RefInfo]:
    refs_path = root / REFS_FILENAME
    if not refs_path.exists():
        return {}
    refs: dict[str, RefInfo] = {}
    for line in refs_path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split(None, 1)
        if len(parts) == 2:
            uuid, raw = parts
            location, kind, name = _parse_refs_line(raw)
            refs[uuid] = RefInfo(location=location, kind=kind, name=name)
    return refs


def _read_text(path: Path) -> str | None:
    try:
        return path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return None


# ── Scanning helpers (shared by scan, check, graph) ──────────────────────────

def scan_anchors(
    root: Path, files: list[str] | None = None
) -> tuple[dict[str, RefInfo], list[str]]:
    """
    Scan source files for ref: anchors.

    Returns ``(refs, errors)`` where:
    - ``refs``   — {uuid: RefInfo} for every valid anchor found
    - ``errors`` — list of range-validation error strings (mismatched
                   :start/:end pairs, cross-file ranges).  Non-empty means
                   one or more UUIDs were skipped and won't appear in refs.

    Duplicate-UUID warnings are still printed to stderr (they're warnings,
    not hard errors — the last occurrence wins).
    """
    if files is None:
        files = tracked_files(root)

    starts: dict[str, str] = {}
    ends:   dict[str, str] = {}
    points: dict[str, tuple[str, str | None]] = {}  # uuid -> (loc, name)

    for rel in files:
        if rel == REFS_FILENAME:
            continue
        full = root / rel
        if not full.is_file():
            continue
        text = _read_text(full)
        if text is None:
            continue

        for lineno, line in enumerate(text.splitlines(), start=1):
            loc = f"{rel}:{lineno}"
            for m in REF_MARKER_RE.finditer(line):
                uuid, suffix = m.group(1), m.group(2)

                if suffix == "start":
                    if uuid in starts:
                        print(f"coderef: warning: duplicate ref:{uuid}:start at {loc} "
                              f"(previous: {starts[uuid]})", file=sys.stderr)
                    starts[uuid] = loc
                elif suffix == "end":
                    if uuid in ends:
                        print(f"coderef: warning: duplicate ref:{uuid}:end at {loc} "
                              f"(previous: {ends[uuid]})", file=sys.stderr)
                    ends[uuid] = loc
                else:
                    if uuid in points:
                        print(f"coderef: warning: duplicate ref:{uuid} at {loc} "
                              f"(previous: {points[uuid][0]})", file=sys.stderr)
                    points[uuid] = (loc, suffix)  # suffix is name or None

    result: dict[str, RefInfo] = {}
    errors: list[str] = []

    for uuid in sorted(set(starts) | set(ends)):
        if uuid not in starts:
            errors.append(f"ref:{uuid}:end at {ends[uuid]} has no matching :start")
            continue
        if uuid not in ends:
            errors.append(f"ref:{uuid}:start at {starts[uuid]} has no matching :end")
            continue
        sf, sl = starts[uuid].rsplit(":", 1)
        ef, el = ends[uuid].rsplit(":", 1)
        if sf != ef:
            errors.append(
                f"ref:{uuid} range crosses files — "
                f":start at {starts[uuid]}, :end at {ends[uuid]}"
            )
            continue
        result[uuid] = RefInfo(location=f"{sf}:{sl}-{el}", kind="range")

    for uuid, (loc, name) in sorted(points.items()):
        if uuid in result:
            print(f"coderef: warning: ref:{uuid} used as both point and range — skipped point",
                  file=sys.stderr)
        else:
            result[uuid] = RefInfo(location=loc, kind="point", name=name)

    return result, errors


def scan_to_refs(root: Path, files: list[str] | None = None) -> dict[str, list[dict]]:
    """
    Scan for to_ref: occurrences.

    Returns {uuid: [{file, line[, commit][, name]}, ...]} where ``commit``
    and ``name`` are present only when the to_ref: body includes them.
    """
    if files is None:
        files = tracked_files(root)

    result: dict[str, list[dict]] = {}
    for rel in files:
        if rel == REFS_FILENAME:
            continue
        full = root / rel
        if not full.is_file():
            continue
        text = _read_text(full)
        if text is None:
            continue
        for lineno, line in enumerate(text.splitlines(), start=1):
            for m in TO_REF_RE.finditer(line):
                parsed = _parse_to_ref(m.group(1))
                uuid = parsed["uuid"]
                occ: dict = {"file": rel, "line": lineno}
                if parsed["commit"]:
                    occ["commit"] = parsed["commit"]
                if parsed["name"]:
                    occ["name"] = parsed["name"]
                result.setdefault(uuid, []).append(occ)

    return result


def _refs_to_file_lines(refs: dict[str, RefInfo]) -> list[str]:
    lines = []
    for uuid, info in sorted(refs.items()):
        val = info.location
        if info.name:
            val += f" {info.name}"
        lines.append(f"{uuid} {val}\n")
    return lines


# ── Commands ──────────────────────────────────────────────────────────────────

def cmd_resolve(args) -> None:
    root = require_root()
    refs = load_refs(root)
    uuid = args.uuid.lower().strip()

    if uuid not in refs:
        print(f"error: uuid '{uuid}' not found in .coderef", file=sys.stderr)
        sys.exit(1)

    info = refs[uuid]
    print(info.display)

    if args.context == 0:
        return

    start_line = info.start_line
    end_line   = info.end_line or start_line

    full = root / info.file
    text = _read_text(full)
    if text is None:
        print(f"error: could not read {info.file}", file=sys.stderr)
        return

    source_lines = text.splitlines()
    total  = len(source_lines)
    ctx    = args.context
    v_from = max(1, start_line - ctx)
    v_to   = min(total, end_line + ctx)
    width  = len(str(v_to))

    print()
    for n in range(v_from, v_to + 1):
        marker = ">" if start_line <= n <= end_line else " "
        print(f"  {marker} {str(n).rjust(width)}: {source_lines[n - 1]}")


def cmd_list(args) -> None:
    root = require_root()
    refs = load_refs(root)
    if not refs:
        print("(no refs found)")
        return
    for uuid, info in sorted(refs.items()):
        print(f"{uuid}  {info.display}  [{info.kind}]")


def cmd_check(args) -> None:
    root = require_root()
    refs = load_refs(root)
    files = tracked_files(root)
    to_refs = scan_to_refs(root, files)

    # Re-scan source to surface any range mismatches not yet caught by scan/hook
    _, range_errors = scan_anchors(root, files)

    # Dangling: UUID not in .coderef and no commit pin (expected to be current)
    dangling: list[tuple[str, int, str]] = []
    # Historical: UUID not in .coderef but pinned to a specific commit (intentional)
    historical: list[tuple[str, int, str, str]] = []  # (file, line, uuid, commit)

    for uuid, occurrences in sorted(to_refs.items()):
        for occ in occurrences:
            commit = occ.get("commit")
            is_pinned = commit is not None and commit != "HEAD"
            if uuid not in refs:
                if is_pinned:
                    historical.append((occ["file"], occ["line"], uuid, commit))
                else:
                    dangling.append((occ["file"], occ["line"], uuid))

    # Orphans: UUID in .coderef with no to_ref: anywhere
    referenced = set(to_refs.keys())
    orphans = [(uuid, info) for uuid, info in sorted(refs.items()) if uuid not in referenced]

    ok = True

    if range_errors:
        ok = False
        print("INVALID RANGES (ref:uuid:start / :end mismatch or cross-file)")
        for e in range_errors:
            print(f"  error: {e}")

    if dangling:
        ok = False
        if range_errors:
            print()
        print("DANGLING to_ref: (UUID has no anchor in .coderef)")
        for rel, lineno, uuid in sorted(dangling):
            print(f"  {rel}:{lineno}: to_ref:{uuid}")

    if historical:
        if dangling:
            print()
        print("HISTORICAL to_ref: (pinned to a specific commit — not checked against current .coderef)")
        for rel, lineno, uuid, commit in sorted(historical):
            print(f"  {rel}:{lineno}: to_ref:{commit}:...:{uuid}")

    if orphans:
        if dangling or historical:
            print()
        label = "ORPHAN ref: (anchor exists in .coderef but is never referenced)"
        if args.strict:
            label += "  [--strict: failing]"
        print(label)
        for uuid, info in orphans:
            print(f"  {uuid}  {info.display}  [{info.kind}]")
        if args.strict:
            ok = False

    if ok and not orphans and not historical:
        ranges = sum(1 for i in refs.values() if i.kind == "range")
        named  = sum(1 for i in refs.values() if i.name)
        pts    = len(refs) - ranges
        parts  = []
        if pts:    parts.append(f"{pts} point{'s' if pts != 1 else ''}")
        if ranges: parts.append(f"{ranges} range{'s' if ranges != 1 else ''}")
        if named:  parts.append(f"{named} named")
        print(f"ok: no issues ({', '.join(parts) or '0 anchors'})")
    elif ok and not orphans:
        print(f"\nok: {len(historical)} historical ref(s) noted — not errors")
    elif ok:
        hist_suffix = f", {len(historical)} historical" if historical else ""
        print(f"\nok: {len(orphans)} orphan(s){hist_suffix} — use --strict to fail on orphans")
    # (range_errors already set ok=False and were printed above)

    if not ok:
        sys.exit(1)


def cmd_scan(args) -> None:
    root = require_root()
    old_refs = load_refs(root)
    new_refs, errors = scan_anchors(root)

    if errors:
        print("INVALID RANGES (commit blocked until fixed)")
        for e in errors:
            print(f"  error: {e}")
        if not args.dry_run:
            sys.exit(1)

    if args.dry_run:
        added   = {u: v for u, v in new_refs.items() if u not in old_refs}
        removed = {u: v for u, v in old_refs.items() if u not in new_refs}
        changed = {u: v for u, v in new_refs.items()
                   if u in old_refs and old_refs[u].display != v.display}
        unchanged = len(new_refs) - len(added) - len(changed)

        for u, v in sorted(added.items()):
            print(f"  + {u}  {v.display}  [{v.kind}]")
        for u, v in sorted(changed.items()):
            print(f"  ~ {u}  {old_refs[u].display}  →  {v.display}  [{v.kind}]")
        for u, v in sorted(removed.items()):
            print(f"  - {u}  {v.display}  [{v.kind}]")
        if not (added or changed or removed):
            print(".coderef is already up to date")
        else:
            print(f"\n(dry run — {len(added)} added, {len(changed)} changed, "
                  f"{len(removed)} removed, {unchanged} unchanged)")
        return

    lines = _refs_to_file_lines(new_refs)
    (root / REFS_FILENAME).write_text("".join(lines), encoding="utf-8")

    ranges = sum(1 for i in new_refs.values() if i.kind == "range")
    named  = sum(1 for i in new_refs.values() if i.name)
    pts    = len(new_refs) - ranges
    parts  = []
    if pts:    parts.append(f"{pts} point{'s' if pts != 1 else ''}")
    if ranges: parts.append(f"{ranges} range{'s' if ranges != 1 else ''}")
    if named:  parts.append(f"{named} named")
    print(f"coderef: .coderef updated ({', '.join(parts) or '0 anchors'})")


def cmd_graph(args) -> None:
    root = require_root()
    refs = load_refs(root)
    files = tracked_files(root)
    to_refs = scan_to_refs(root, files)

    graph: dict[str, dict] = {}
    for uuid, info in sorted(refs.items()):
        graph[uuid] = {
            "location": info.location,
            "kind": info.kind,
            **({"name": info.name} if info.name else {}),
            "referenced_by": to_refs.get(uuid, []),
        }

    for uuid, occurrences in sorted(to_refs.items()):
        if uuid not in graph:
            graph[uuid] = {
                "location": None,
                "kind": None,
                "referenced_by": occurrences,
                "dangling": True,
            }

    print(json.dumps(graph, indent=2))


def cmd_install(args) -> None:
    root = require_root()
    hooks_dir = root / ".git" / "hooks"
    if not hooks_dir.is_dir():
        print("error: .git/hooks directory not found", file=sys.stderr)
        sys.exit(1)

    script_dir = Path(__file__).resolve().parent
    coderef_hooks = script_dir.parent / "hooks"
    if not (coderef_hooks / "pre-commit").exists():
        print(f"error: hook source not found at {coderef_hooks}", file=sys.stderr)
        sys.exit(1)

    # Install via the bundled shell script for consistency
    install_sh = script_dir.parent / "install.sh"
    if install_sh.exists():
        subprocess.run(["bash", str(install_sh), str(root)], check=True)
    else:
        # Fallback: copy pre-commit directly
        dst = hooks_dir / "pre-commit"
        shutil.copy2(coderef_hooks / "pre-commit", dst)
        dst.chmod(dst.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
        print(f"coderef: hook installed at {dst}")
        refs_path = root / REFS_FILENAME
        if not refs_path.exists():
            refs_path.write_text("", encoding="utf-8")
        print("coderef: installation complete")


# ── Entry point ───────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="coderef",
        description="Stable UUID-based in-source code reference system",
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>")

    # resolve
    p = sub.add_parser("resolve", help="Resolve a UUID to its file:line location")
    p.add_argument("uuid", help="8-char hex UUID")
    p.add_argument("--context", "-C", metavar="N", type=int, default=0,
                   help="Show N lines of source context around the anchor (default: 0)")
    p.set_defaults(func=cmd_resolve)

    # list
    p = sub.add_parser("list", help="List all UUID anchors and their locations")
    p.set_defaults(func=cmd_list)

    # check
    p = sub.add_parser("check",
                       help="Audit refs: report dangling to_ref: and orphan ref: anchors")
    p.add_argument("--strict", action="store_true",
                   help="Exit 1 on orphan anchors as well as dangling refs")
    p.set_defaults(func=cmd_check)

    # scan
    p = sub.add_parser("scan",
                       help="Scan source files and rewrite .coderef (no git commit required)")
    p.add_argument("--dry-run", "-n", action="store_true",
                   help="Show what would change without writing .coderef")
    p.set_defaults(func=cmd_scan)

    # graph
    p = sub.add_parser("graph",
                       help="Emit the full anchor→reference graph as JSON")
    p.set_defaults(func=cmd_graph)

    # install
    p = sub.add_parser("install", help="Install the git hooks (pre-commit, post-checkout, post-merge)")
    p.set_defaults(func=cmd_install)

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
